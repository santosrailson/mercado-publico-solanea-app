# Backend Configuration
PROJECT_NAME="Mercado Público API"
VERSION="1.0.0"
DESCRIPTION="API para gestão do Mercado Público de Solânea"

# Security
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (PostgreSQL via Docker Compose)
DATABASE_URL=postgresql://mercado:mercado123@db:5432/mercado

# Para SQLite (desenvolvimento local sem Docker):
# DATABASE_URL=sqlite:///./mercado.db

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
